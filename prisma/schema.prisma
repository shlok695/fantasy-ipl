generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(uuid())
  name        String   @unique
  password    String
  budget      Float    @default(100.0) // 100 Cr default budget
  totalPoints Float    @default(0.0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  players     Player[]
  auctionWins AuctionState[]
}

model Player {
  id           String   @id @default(uuid())
  number       Int?
  name         String
  country      String?
  acquisition  String?
  type         String?
  role         String?
  basePrice    String?
  auctionPrice Float?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  userId       String?
  user         User?    @relation(fields: [userId], references: [id])

  points       PlayerPoints[]
  auctionState AuctionState?
}

model PlayerPoints {
  id        String   @id @default(uuid())
  playerId  String
  player    Player   @relation(fields: [playerId], references: [id])
  matchId   String?  // Changed to String to support long API IDs
  points    Float    @default(0.0)
  
  // Granular Stats for Leaderboards
  runs       Int      @default(0)
  ballsFaced Int      @default(0)
  wickets    Int      @default(0)
  dotBalls   Int      @default(0)
  
  createdAt DateTime @default(now())
}

// Singleton state for the Live Multiplayer Auction
model AuctionState {
  id              String   @id @default("global")
  
  currentPlayerId String?  @unique
  player          Player?  @relation(fields: [currentPlayerId], references: [id])
  
  highestBid      Float    @default(0)
  highestBidderId String?
  highestBidder   User?    @relation(fields: [highestBidderId], references: [id])
  
  status          String   @default("WAITING") // WAITING, BIDDING, SUMMARY
  readyTeams      String?  // Comma-separated user IDs who clicked Ready
}
