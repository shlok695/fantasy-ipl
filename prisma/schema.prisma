generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id          String         @id @default(uuid())
  name        String         @unique
  password    String
  budget      Float          @default(125.0)
  totalPoints Float          @default(0.0)
  bonusPoints Float          @default(0.0)
  captainId   String?        @unique
  viceCaptainId String?      @unique
  iplTeam     String?
  rtmUsed     Boolean        @default(false)
  lastActive  DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  auctionWins AuctionState[]
  players     Player[]
  simulationBonusAdjustments SimulationTeamBonusAdjustment[]
  captain     Player?        @relation("CaptainSelection", fields: [captainId], references: [id])
  viceCaptain Player?        @relation("ViceCaptainSelection", fields: [viceCaptainId], references: [id])
}

model Player {
  id           String         @id @default(uuid())
  number       Int?
  name         String
  country      String?
  acquisition  String?
  type         String?
  role         String?
  iplTeam      String?
  basePrice    String?
  auctionPrice Float?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  userId       String?
  auctionState AuctionState?
  user         User?          @relation(fields: [userId], references: [id])
  points       PlayerPoints[]
  captainOf    User?          @relation("CaptainSelection")
  viceCaptainOf User?         @relation("ViceCaptainSelection")
}

model PlayerPoints {
  id                String            @id @default(uuid())
  playerId          String
  simulationBatchId String?
  matchId           String?
  points            Float             @default(0.0)
  runs              Int               @default(0)
  ballsFaced        Int               @default(0)
  wickets           Int               @default(0)
  dotBalls          Int               @default(0)
  breakdownJson     String?
  statsJson         String?
  scoreVersion      String?
  calculationHash   String?
  source            String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @default(now()) @updatedAt
  player            Player            @relation(fields: [playerId], references: [id])
  match             Match?            @relation(fields: [matchId], references: [id])
  simulationBatch   SimulationBatch?  @relation(fields: [simulationBatchId], references: [id], onDelete: SetNull)

  @@index([matchId])
  @@unique([playerId, matchId])
}

model Match {
  id         String         @id
  displayId  String?
  shortTitle String?
  title      String?
  season     String?
  status     String?
  team1Code  String?
  team2Code  String?
  team1Name  String?
  team2Name  String?
  source     String?
  startedAt  DateTime?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  playerPoints PlayerPoints[]

  @@index([displayId])
}

model AuctionState {
  id              String  @id @default("global")
  currentPlayerId String? @unique
  highestBid      Float   @default(0)
  highestBidderId String?
  status          String   @default("WAITING")
  liveRoomVisible Boolean  @default(false)
  readyTeams      String?
  updatedAt       DateTime? @updatedAt
  highestBidder   User?    @relation(fields: [highestBidderId], references: [id])
  player          Player?  @relation(fields: [currentPlayerId], references: [id])
}

model SimulationBatch {
  id                    String                         @id
  label                 String
  sourceSeason          String
  notes                 String?
  createdAt             DateTime                       @default(now())
  playerPoints          PlayerPoints[]
  teamBonusAdjustments  SimulationTeamBonusAdjustment[]
}

model SimulationTeamBonusAdjustment {
  id                String           @id @default(uuid())
  simulationBatchId String
  userId            String
  matchId           String?
  iplTeam           String?
  points            Float
  createdAt         DateTime         @default(now())
  simulationBatch   SimulationBatch  @relation(fields: [simulationBatchId], references: [id], onDelete: Cascade)
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LiveMatchState {
  id            String   @id
  rawPayload    String   
  processedHash String   
  lastUpdated   DateTime @default(now())
}
