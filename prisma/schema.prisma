generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id          String         @id @default(uuid())
  name        String         @unique
  password    String
  budget      Float          @default(125.0)
  totalPoints Float          @default(0.0)
  bonusPoints Float          @default(0.0)
  captainId   String?        @unique
  viceCaptainId String?      @unique
  iplTeam     String?
  rtmUsed     Boolean        @default(false)
  lastActive  DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  auctionWins AuctionState[]
  players     Player[]
  captain     Player?        @relation("CaptainSelection", fields: [captainId], references: [id])
  viceCaptain Player?        @relation("ViceCaptainSelection", fields: [viceCaptainId], references: [id])
}

model Player {
  id           String         @id @default(uuid())
  number       Int?
  name         String
  country      String?
  acquisition  String?
  type         String?
  role         String?
  iplTeam      String?
  basePrice    String?
  auctionPrice Float?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  userId       String?
  auctionState AuctionState?
  user         User?          @relation(fields: [userId], references: [id])
  points       PlayerPoints[]
  captainOf    User?          @relation("CaptainSelection")
  viceCaptainOf User?         @relation("ViceCaptainSelection")
}

model PlayerPoints {
  id         String   @id @default(uuid())
  playerId   String
  matchId    String?
  points     Float    @default(0.0)
  runs       Int      @default(0)
  ballsFaced Int      @default(0)
  wickets    Int      @default(0)
  dotBalls   Int      @default(0)
  createdAt  DateTime @default(now())
  player     Player   @relation(fields: [playerId], references: [id])
}

model AuctionState {
  id              String  @id @default("global")
  currentPlayerId String? @unique
  highestBid      Float   @default(0)
  highestBidderId String?
  status          String   @default("WAITING")
  liveRoomVisible Boolean  @default(false)
  readyTeams      String?
  updatedAt       DateTime? @updatedAt
  highestBidder   User?    @relation(fields: [highestBidderId], references: [id])
  player          Player?  @relation(fields: [currentPlayerId], references: [id])
}
